# ============================================
# Sales Doctor ↔ MoySklad Integration
# Marketplace Edition - Environment Variables
# ============================================

# --- Application ---
# JWT uses APP_SECRET_KEY — must be strong and stable in production (min 32 chars).
APP_SECRET_KEY=change-this-to-a-secure-random-string-min-32-chars
DEBUG=false
CORS_ORIGINS=https://your-domain.com,https://app.your-domain.com

# SPA URL for MoySklad OAuth redirect after success/error (must match your deployed UI).
FRONTEND_BASE_URL=https://app.your-domain.com

# Optional: session length (minutes). Default 10080 = 7 days.
# JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- Database ---
# For local development (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./integration.db
# For production (PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://user:password@db:5432/integration

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- MoySklad OAuth (Marketplace — majburiy OAuth oqimi uchun) ---
# Developer console: https://online.moysklad.ru/api/apps/
MOYSKLAD_CLIENT_ID=your-moysklad-app-client-id
MOYSKLAD_CLIENT_SECRET=your-moysklad-app-client-secret
# Backend callback — MoySklad ilovasidagi Redirect URI bilan bir xil bo‘lishi kerak
MOYSKLAD_REDIRECT_URI=https://api.your-domain.com/api/auth/moysklad/callback

# --- MoySklad API (opsional: dev/test uchun global token; ishlab tenant token ishlatiladi) ---
MOYSKLAD_TOKEN=
MOYSKLAD_BASE_URL=https://api.moysklad.ru/api/remap/1.2

# --- Sales Doctor API ---
SALESDOCTOR_API_KEY=your-salesdoctor-api-key
SALESDOCTOR_BASE_URL=https://api.salesdoctor.uz/v2

# --- Sync Intervals (seconds) ---
STOCK_SYNC_INTERVAL=15
DEBT_SYNC_INTERVAL=600
CLIENT_SYNC_INTERVAL=300

# --- Currency Exchange Rate ---
# MoySklad prices are in USD, Sales Doctor expects UZS (sum)
# 1 USD = ? UZS — check current rate at uzex.uz
USD_TO_UZS_RATE=12695

# --- Webhook ---
WEBHOOK_SECRET=your-webhook-secret-key
WEBHOOK_URL=https://your-domain.com/webhook
# Public HTTPS base URL — used for MoySklad webhook auto-registration.
# Must start with https://. MoySklad posts to {PUBLIC_BASE_URL}/api/webhook/moysklad
PUBLIC_BASE_URL=https://app.pipely.uz

# --- Payment Providers ---
# Payme
PAYME_MERCHANT_ID=your-payme-merchant-id
PAYME_SECRET_KEY=your-payme-secret

# Click
CLICK_SERVICE_ID=your-click-service-id
CLICK_MERCHANT_ID=your-click-merchant-id
CLICK_SECRET_KEY=your-click-secret

# YooKassa (for Russia)
YOOKASSA_SHOP_ID=your-yookassa-shop-id
YOOKASSA_SECRET_KEY=your-yookassa-secret
